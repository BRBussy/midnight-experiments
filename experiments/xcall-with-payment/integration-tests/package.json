{
  "name": "@midnight-experiments/xcall-with-payment-integration-tests",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Live suite for the xcall-with-payment experiment: the rejection-pinning bench (callee Zswap custody is unsupported) plus the atomic two-root-call composition test (cross-contract call + payment merged into one transaction). Gated by RUN_INTEGRATION_TESTS; requires `yarn compile:zk` output and a running node + indexer + proof server.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "bench": "RUN_INTEGRATION_TESTS=1 vitest run tests/ --bail 1 --disable-console-intercept",
    "bench:payment": "RUN_INTEGRATION_TESTS=1 vitest run tests/xcall-with-payment.test.ts --bail 1 --disable-console-intercept",
    "test:atomic": "RUN_INTEGRATION_TESTS=1 vitest run tests/xcall-with-payment-atomic.test.ts --bail 1 --disable-console-intercept"
  },
  "dependencies": {
    "@midnight-experiments/lib": "*",
    "@midnight-experiments/test-harness-benchmark": "*",
    "@midnight-experiments/xcall-with-payment-contract": "*",
    "@midnight-ntwrk/midnight-js": "5.0.0-beta.4",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "5.0.0-beta.4",
    "@midnight-ntwrk/midnight-js-protocol": "5.0.0-beta.4",
    "@midnight-ntwrk/midnight-js-types": "5.0.0-beta.4"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
